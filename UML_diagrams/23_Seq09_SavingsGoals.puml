@startuml Seq09_SavingsGoals
!theme plain
participant User
participant "React Frontend" as Frontend
participant "Savings API" as Backend
participant "Goal\nEngine" as GoalEngine
participant "LLM API" as LLM
participant "MySQL DB" as DB

autonumber

Note over User,DB: **CREATE SAVINGS GOAL**

User -> Frontend: Navigate to Savings Goals
Frontend -> Frontend: Display savings goals page
User -> Frontend: Click "Create New Goal"

Frontend -> Frontend: Show goal creation form
Note over Frontend: Form fields:
Note over Frontend: - Goal name (e.g., "Vacation")
Note over Frontend: - Target amount
Note over Frontend: - Target date
Note over Frontend: - Goal category

User -> Frontend: Enter: Goal="Vacation", Target=₹50000,\nDeadline=Dec 2026

Frontend -> Frontend: Validate input
Frontend -> Backend: POST /goals/create\n{name: "Vacation", target_amount: 50000,\ntarget_date: "2026-12-31"}

Backend -> GoalEngine: create_goal(name, target_amount, target_date)

GoalEngine -> GoalEngine: Calculate days remaining
GoalEngine -> GoalEngine: days_left = 245 days

GoalEngine -> GoalEngine: Calculate required savings rate
GoalEngine -> GoalEngine: daily_savings = 50000 / 245 = 204/day
GoalEngine -> GoalEngine: monthly_savings = 204 * 30 = 6120/month
GoalEngine -> GoalEngine: weekly_savings = 204 * 7 = 1428/week

GoalEngine -> DB: INSERT INTO savings_goals\n(user_id, name, target_amount, target_date,\ncreated_date, current_amount, status)
DB --> GoalEngine: {goal_id}

GoalEngine --> Backend: {goal: {...}}
Backend --> Frontend: {status: "success", goal}

Frontend -> Frontend: Show success
Frontend --> User: Goal created

Note over User,DB: **VIEW ALL GOALS**

User -> Frontend: View Goals page
Frontend -> Backend: GET /goals

Backend -> DB: SELECT * FROM savings_goals\nWHERE user_id AND status IN ('active', 'completed')
DB --> Backend: [goal1, goal2, ...]

Backend -> GoalEngine: Calculate progress for each goal

loop For Each Goal
    GoalEngine -> DB: SELECT SUM(amount) FROM transactions\nWHERE goal_id AND is_savings=true
    DB --> GoalEngine: total_saved
    
    GoalEngine -> GoalEngine: progress = (total_saved / target) * 100
    GoalEngine -> GoalEngine: days_remaining = (target_date - today)
    GoalEngine -> GoalEngine: status = "on_track" or "behind_schedule"
end

Backend --> Frontend: {goals: [{id, name, target, current, progress,\ndays_remaining, status}, ...]}

Frontend -> Frontend: Render goal progress cards

Note over Frontend: Goal Card 1 - Vacation:
Note over Frontend: ₹18,000 / ₹50,000 (36%)
Note over Frontend: 245 days remaining
Note over Frontend: Status: ✅ On Track

Note over Frontend: Goal Card 2 - Emergency Fund:
Note over Frontend: ₹8,500 / ₹100,000 (8.5%)
Note over Frontend: 365 days remaining
Note over Frontend: Status: ⚠️ Behind Schedule

Frontend --> User: Display all goals with progress

Note over User,DB: **TRACK GOAL PROGRESS**

User -> Frontend: Click on Vacation goal
Frontend -> Backend: GET /goals/{goal_id}/progress

Backend -> DB: Fetch goal and transaction history
DB --> Backend: goal_data, savings_history

Backend -> GoalEngine: calculate_detailed_progress(goal)

GoalEngine -> GoalEngine: progress_percent = 36%
GoalEngine -> GoalEngine: target_amount = 50000
GoalEngine -> GoalEngine: current_saved = 18000
GoalEngine -> GoalEngine: amount_remaining = 32000

GoalEngine -> GoalEngine: Calculate timeline
GoalEngine -> GoalEngine: days_passed = 120 days
GoalEngine -> GoalEngine: days_remaining = 245 days
GoalEngine -> GoalEngine: total_days = 365 days

GoalEngine -> GoalEngine: Calculate milestone progress
GoalEngine -> GoalEngine: By this date (90 days), should have: 14600
GoalEngine -> GoalEngine: Actually saved: 18000 ✅ Ahead

Backend --> Frontend: {goal_detail}

Frontend -> Frontend: Render progress details
Frontend -> Frontend: Show progress bar with milestones

Note over Frontend: Progress Timeline:
Note over Frontend: Today: ₹18,000 saved (36%)
Note over Frontend: 90-day milestone: ₹14,600 (reached ₹18,000) ✅
Note over Frontend: 180-day milestone: ₹29,200
Note over Frontend: Final: ₹50,000 by Dec 31

Frontend --> User: Display detailed progress

Note over User,DB: **AI ACCELERATION TIPS**

User -> Frontend: Click "Get AI Tips"
Frontend -> Backend: GET /goals/{goal_id}/ai-tips

Backend -> Backend: Analyze spending patterns
Backend -> DB: Fetch user's expense data
DB --> Backend: transactions, categories, budgets

Backend -> Backend: Identify savings opportunities
Backend -> Backend: User spends 38.7% on Food
Backend -> Backend: Potential savings: 5-10% = ₹150-300/month

Backend -> Backend: Compile goal profile
Backend -> Backend: goal_context = {
Note over Backend: name: "Vacation",
Note over Backend: target: 50000,
Note over Backend: deadline: "2026-12-31",
Note over Backend: current_status: "on_track",
Note over Backend: user_spending: {...}
Note over Backend: }

Backend -> LLM: POST /generate-tips\n{goal_profile, user_data}

LLM -> LLM: Generate personalized tips
LLM --> Backend: {tips: [
Note over LLM: "1. Reduce restaurant visits by 2x/week\n   to save ₹200/month"
Note over LLM: "2. Use grocery coupons and cashback apps\n   potential ₹100/month"
Note over LLM: "3. Cut entertainment spending by 10%\n   saves ₹60/month"
Note over LLM: "4. Total potential: ₹360/month\n   accelerates goal by 45 days"
]}

Backend --> Frontend: {tips: [...]}
Frontend -> Frontend: Display tips as cards
Frontend --> User: Show acceleration recommendations

Note over User,DB: **MILESTONE TRACKING**

User -> Frontend: View milestones
Frontend -> Backend: GET /goals/{goal_id}/milestones

Backend -> GoalEngine: calculate_milestones(goal)

GoalEngine -> GoalEngine: Generate quarterly milestones
GoalEngine -> GoalEngine: Q1 (90 days): 14600
GoalEngine -> GoalEngine: Q2 (180 days): 29200
GoalEngine -> GoalEngine: Q3 (270 days): 43800
GoalEngine -> GoalEngine: Q4 (365 days): 50000

Backend --> Frontend: {milestones: [...]}

Frontend -> Frontend: Show milestone tracking
Frontend --> User: Display milestone progress

Note over User,DB: **UPDATE GOAL STATUS**

alt Goal Completed
    User -> Frontend: Saved ₹50,000 complete!
    Frontend -> Backend: PUT /goals/{goal_id}\n{status: "completed"}
    
    Backend -> DB: UPDATE savings_goals\nSET status='completed', completed_date=TODAY
    DB --> Backend: {success}
    
    Backend -> Backend: Archive goal
    Backend --> Frontend: {status: "success"}
    
    Frontend -> Frontend: Show celebration message
    Frontend --> User: 🎉 Goal completed!
    
else Modify Goal
    User -> Frontend: Need to extend deadline
    Frontend -> Frontend: Show edit form
    User -> Frontend: Change deadline to Jan 2027
    
    Frontend -> Backend: PUT /goals/{goal_id}\n{target_date: "2027-01-31"}
    
    Backend -> GoalEngine: Recalculate timeline
    GoalEngine -> GoalEngine: New daily rate: 190/day
    GoalEngine -> GoalEngine: New monthly: 5700/month
    
    Backend -> DB: UPDATE savings_goals
    DB --> Backend: {success}
    
    Frontend -> Frontend: Update display
    Frontend --> User: Goal updated

end

Note over User,DB: **DELETE GOAL**

User -> Frontend: Click delete goal
Frontend -> Frontend: Show confirmation
User -> Frontend: Confirm deletion

Frontend -> Backend: DELETE /goals/{goal_id}

Backend -> DB: DELETE FROM savings_goals\nWHERE id={goal_id} AND user_id={user_id}
DB --> Backend: {success}

Backend --> Frontend: {status: "deleted"}
Frontend -> Frontend: Remove from list
Frontend --> User: Goal deleted

@enduml
