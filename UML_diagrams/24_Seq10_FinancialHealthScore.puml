@startuml Seq10_FinancialHealthScore
!theme plain
participant User
participant "React Frontend" as Frontend
participant "Score API" as Backend
participant "Scoring\nEngine" as ScoringEng
participant "Analytics" as Analytics
participant "MySQL DB" as DB

autonumber

Note over User,DB: **REQUEST FINANCIAL HEALTH SCORE**

User -> Frontend: Navigate to Financial Health
Frontend -> Frontend: Show loading state
Frontend -> Backend: GET /financial-health/score

Backend -> DB: Fetch user's financial data
Backend -> DB: SELECT * FROM users WHERE id={user_id}
DB --> Backend: user_profile

Backend --> Frontend: {status: "calculating"}
Frontend -> Frontend: Show calculating state

Note over User,DB: **COMPONENT 1: SAVINGS RATE**

Backend -> ScoringEng: calculate_savings_rate()

ScoringEng -> DB: SELECT SUM(amount) as income\nFROM transactions WHERE type='income'
DB --> ScoringEng: total_income = 80000

ScoringEng -> DB: SELECT SUM(amount) as spending\nFROM transactions WHERE type='expense'
DB --> ScoringEng: total_spending = 54200

ScoringEng -> Analytics: Identify savings
Analytics -> Analytics: savings = 80000 - 54200 = 25800
Analytics -> Analytics: savings_rate = (25800 / 80000) * 100 = 32.25%

Note over Analytics: Savings Score Calculation:
Note over Analytics: Ideal: 20-30% = 90/100 points
Note over Analytics: Actual: 32.25% = 100/100 points (excellent)

ScoringEng -> ScoringEng: savings_score = 100

ScoringEng --> Backend: {component: "savings_rate", score: 100,\ndetails: {...}}

Note over User,DB: **COMPONENT 2: BUDGET CONTROL**

Backend -> ScoringEng: calculate_budget_control()

ScoringEng -> DB: SELECT * FROM budgets WHERE user_id
DB --> ScoringEng: [budget1, budget2, ...]

ScoringEng -> Analytics: Calculate budget adherence

loop For Each Budget
    Analytics -> DB: Fetch actual spending vs budget
    DB --> Analytics: {budget_amount, actual_spent}
    
    Analytics -> Analytics: Calculate variance %
    alt Under Budget
        Analytics -> Analytics: points += 10
    else Over Budget (0-10%)
        Analytics -> Analytics: points += 5
    else Over Budget (10-20%)
        Analytics -> Analytics: points -= 5
    else Over Budget (>20%)
        Analytics -> Analytics: points -= 10
    end
end

Analytics -> Analytics: total_budget_score = 85
Note over Analytics: 8/10 budgets on track = 80/100
Note over Analytics: slight overspend on 2 = -15/100

ScoringEng -> ScoringEng: budget_score = 85

ScoringEng --> Backend: {component: "budget_control", score: 85,\ndetails: {...}}

Note over User,DB: **COMPONENT 3: SPENDING STABILITY**

Backend -> ScoringEng: calculate_spending_stability()

ScoringEng -> Analytics: Analyze spending volatility

Analytics -> DB: SELECT DATE_FORMAT(date, '%Y-%m') as month,\nSUM(amount) as monthly_spending\nFROM transactions GROUP BY month\nORDER BY date DESC LIMIT 6
DB --> Analytics: [2026-05: 5420, 2026-04: 6200,\n2026-03: 4920, 2026-02: 5850, ...]

Analytics -> Analytics: Calculate standard deviation
Analytics -> Analytics: monthly_avg = 5510
Analytics -> Analytics: std_dev = 450
Analytics -> Analytics: coefficient_of_variation = (450/5510)*100 = 8.17%

Note over Analytics: Stability Score:
Note over Analytics: CV < 5% = 100 (very stable)
Note over Analytics: CV 5-10% = 85 (good stability)
Note over Analytics: CV 10-15% = 70 (moderate)
Note over Analytics: CV > 15% = 50 (unstable)

Analytics -> Analytics: stability_score = 85

ScoringEng -> ScoringEng: stability_score = 85

ScoringEng --> Backend: {component: "spending_stability", score: 85,\ndetails: {...}}

Note over User,DB: **COMPONENT 4: DEBT MANAGEMENT**

Backend -> ScoringEng: calculate_debt_score()

ScoringEng -> DB: SELECT * FROM debts\nWHERE user_id
DB --> ScoringEng: [loan1, loan2, ...]

alt No Debts
    ScoringEng -> ScoringEng: debt_score = 100
else Debts Exist
    ScoringEng -> Analytics: Calculate debt metrics
    
    Analytics -> Analytics: total_debt = 50000
    Analytics -> Analytics: total_income = 80000
    Analytics -> Analytics: debt_to_income_ratio = 62.5%
    
    Analytics -> Analytics: outstanding_payments = 0 (all current)
    
    Note over Analytics: Debt Score Calculation:
    Note over Analytics: DTI < 30% = 100 (excellent)
    Note over Analytics: DTI 30-50% = 70 (good)
    Note over Analytics: DTI 50-70% = 40 (moderate - needs attention)
    Note over Analytics: DTI > 70% = 20 (high risk)
    
    Analytics -> Analytics: ratio_score = 40
    
    Analytics -> Analytics: payment_history (no missed = +20)
    Analytics -> Analytics: debt_score = 40 + 20 = 60
end

ScoringEng -> ScoringEng: debt_score = 60

ScoringEng --> Backend: {component: "debt_management", score: 60,\ndetails: {...}}

Note over User,DB: **COMPONENT 5: EMERGENCY FUND**

Backend -> ScoringEng: calculate_emergency_fund_score()

ScoringEng -> DB: SELECT current_amount FROM savings_goals\nWHERE goal_name='Emergency Fund'
DB --> ScoringEng: emergency_fund_balance = 8500

ScoringEng -> Analytics: Calculate emergency fund adequacy

Analytics -> Analytics: monthly_expenses = 5510
Analytics -> Analytics: months_covered = 8500 / 5510 = 1.54 months

Note over Analytics: Emergency Fund Score:
Note over Analytics: 0-3 months = Score based on %, max 50
Note over Analytics: 3-6 months = 70-85
Note over Analytics: 6+ months = 100

Analytics -> Analytics: ef_score = (1.54/3) * 50 = 25

ScoringEng -> ScoringEng: emergency_fund_score = 25

ScoringEng --> Backend: {component: "emergency_fund", score: 25,\ndetails: {...}}

Note over User,DB: **CALCULATE OVERALL SCORE**

Backend -> ScoringEng: calculate_overall_score()

ScoringEng -> ScoringEng: scores = [100, 85, 85, 60, 25]
ScoringEng -> ScoringEng: weights = [0.25, 0.20, 0.20, 0.20, 0.15]

ScoringEng -> ScoringEng: weighted_average = (100*0.25) + (85*0.20) +\n(85*0.20) + (60*0.20) + (25*0.15)
ScoringEng -> ScoringEng: weighted_average = 25 + 17 + 17 + 12 + 3.75 = 74.75

ScoringEng -> ScoringEng: overall_score = 75 (rounded)

Note over ScoringEng: Score Range & Grade:
Note over ScoringEng: 90-100: A (Excellent)
Note over ScoringEng: 75-89: B (Good)
Note over ScoringEng: 60-74: C (Moderate)
Note over ScoringEng: 45-59: D (Poor)
Note over ScoringEng: <45: F (Critical)

ScoringEng -> ScoringEng: grade = "B" (Good)

ScoringEng -> DB: INSERT INTO financial_scores\n(user_id, overall_score, savings_score, budget_score,\nstability_score, debt_score, ef_score, calculated_at)
DB --> ScoringEng: {score_id}

ScoringEng --> Backend: {overall_score: 75, grade: "B",\ncomponents: {...}}

Note over User,DB: **DISPLAY SCORE REPORT**

Backend --> Frontend: {score: 75, grade: "B",\ntitle: "Good Financial Health",\ncomponents: [{name: "Savings Rate",\nscore: 100}, ...]}

Frontend -> Frontend: Render score display

Note over Frontend: Large Score Display:
Note over Frontend: 🎯 75
Note over Frontend: Grade: B (Good)
Note over Frontend: Status: Your financial health is good!

Frontend -> Frontend: Render component breakdown

Note over Frontend: Component Cards:
Note over Frontend: ✅ Savings Rate: 100/100 (Excellent)
Note over Frontend: ✅ Budget Control: 85/100 (Good)
Note over Frontend: ✅ Spending Stability: 85/100 (Good)
Note over Frontend: ⚠️ Debt Management: 60/100 (Moderate)
Note over Frontend: ❌ Emergency Fund: 25/100 (Needs Improvement)

Frontend -> Frontend: Render recommendations

Note over Frontend: 📌 Top Recommendations:
Note over Frontend: 1. Build emergency fund (currently 1.5 months)\n   Target: 6 months = ₹33,060
Note over Frontend: 2. Focus on debt reduction\n   DTI is 62.5%, target: <30%
Note over Frontend: 3. Maintain your excellent savings rate!

Frontend --> User: Display complete financial health report

Note over User,DB: **TREND ANALYSIS**

Backend -> Analytics: Calculate score trends

Analytics -> DB: SELECT overall_score, calculated_at\nFROM financial_scores\nWHERE user_id ORDER BY calculated_at DESC LIMIT 12
DB --> Analytics: [75 (today), 72 (1 mo ago), 70 (2 mo ago), ...]

Analytics -> Analytics: trend = +5 over 2 months (improving!)

Backend --> Frontend: {trend: "improving", change: "+5"}
Frontend -> Frontend: Show trend indicator
Frontend -> Frontend: Display trend chart
Frontend --> User: Show improvement over time

@enduml
