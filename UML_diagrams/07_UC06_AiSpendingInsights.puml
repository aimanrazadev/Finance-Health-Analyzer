usecase "Detect Subscription Spending" as U11

usecase "Create Spending Summary" as U12
usecase "Build AI Insight Prompt" as U13
usecase "Send Summary to AI Service" as U14
usecase "Generate Insight Text" as U15

usecase "Save AI Insights" as U16
usecase "Display Insight Cards" as U17
usecase "Regenerate Insights" as U18

usecase "Show No Data Message" as U19
usecase "Handle AI Timeout" as U20
usecase "Handle Invalid AI Response" as U21

}

