@startuml
title UC03 - Statement Upload Use Case

top to bottom direction

skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 55
skinparam packageStyle rectangle
skinparam shadowing false

actor "User" as User
actor "File Parser\nPandas / OpenPyXL / PDFPlumber" as Parser
database "MySQL Database" as DB

rectangle "Statement Upload Module" {

usecase "Upload Bank Statement" as U1

usecase "Select Statement File" as U2
usecase "Choose CSV / Excel / PDF" as U3
