@startuml
title UC05 - Dashboard and Reports Use Case

top to bottom direction

skinparam linetype ortho
skinparam ranksep 90
skinparam nodesep 55
skinparam packageStyle rectangle
skinparam shadowing false

actor "User" as User
database "MySQL Database" as DB

rectangle "Dashboard & Reports Module" {

usecase "View Dashboard & Reports" as U1

usecase "Select Month / Year Filter" as U2
usecase "Fetch User Transactions" as U3

usecase "Calculate Total Income" as U4
usecase "Calculate Total Expenses" as U5
usecase "Calculate Total Savings" as U6
usecase "Calculate Savings Rate" as U7
usecase "Find Top Spending Category" as U8
usecase "Count Total Transactions" as U9

usecase "Display Summary Cards" as U10

usecase "Generate Category Pie Chart" as U11
usecase "Generate Category Bar Graph" as U12
usecase "Generate Income vs Expense Chart" as U13
usecase "Generate Monthly Spending Line Chart" as U14
usecase "Generate Top Merchants Chart" as U15

usecase "Apply Date Filters" as U16
usecase "Show Loading State" as U17
usecase "Show Empty State" as U18
usecase "Show No Data Message" as U19

}

